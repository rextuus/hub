{% extends 'base.html.twig' %}

{% block title %}Hub - Your Mini App Collection{% endblock %}

{% block body %}
<nav class="navbar navbar-expand-lg navbar-dark bg-dark mb-5 shadow-sm">
    <div class="container">
        <a class="navbar-brand d-flex align-items-center" href="{{ path('app_landing_page') }}">
            {{ ux_icon('lucide:layout-grid', {class: 'me-2 text-primary'}) }}
            <span class="fw-bold">Hub</span>
        </a>
        <button class="navbar-expand-lg" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
            <span class="navbar-toggler-icon"></span>
        </button>
        <div class="collapse navbar-collapse" id="navbarNav">
            <ul class="navbar-nav ms-auto align-items-center">
                {% if is_granted('ROLE_ADMIN') %}
                    <li class="nav-item">
                        <a class="nav-link" href="{{ path('admin') }}">
                            {{ ux_icon('lucide:settings', {class: 'me-1'}) }}Admin
                        </a>
                    </li>
                {% endif %}
                <li class="nav-item ms-lg-3">
                    {% if app.user %}
                        <div class="dropdown">
                            <button class="btn btn-outline-light dropdown-toggle d-flex align-items-center" type="button" data-bs-toggle="dropdown">
                                {{ ux_icon('lucide:user', {class: 'me-1'}) }}{{ app.user.userIdentifier }}
                            </button>
                            <ul class="dropdown-menu dropdown-menu-end">
                                <li><a class="dropdown-item d-flex align-items-center text-danger" href="{{ path('app_logout') }}">
                                    {{ ux_icon('lucide:log-out', {class: 'me-2'}) }}Logout
                                </a></li>
                            </ul>
                        </div>
                    {% else %}
                        <a class="btn btn-primary d-flex align-items-center" href="{{ path('app_login') }}">
                            {{ ux_icon('lucide:log-in', {class: 'me-1'}) }}Login
                        </a>
                    {% endif %}
                </li>
            </ul>
        </div>
    </div>
</nav>

<div class="container">
    <div class="row mb-5">
        <div class="col-lg-8 mx-auto text-center">
            <h1 class="display-4 fw-bold mb-3">Welcome to your Tool Hub</h1>
            <p class="lead text-muted">A collection of small, powerful tools designed to make your daily tasks easier. All in one place, sharing the comfort of a unified platform.</p>
        </div>
    </div>

    <div class="row g-4 mb-5">
        {% for project in projects %}
            <div class="col-md-6 col-lg-4">
                <div class="card h-100 shadow-sm hover-shadow border-0 transition">
                    <div class="card-body p-4 text-center">
                        <div class="bg-primary bg-opacity-10 text-primary rounded-circle d-inline-flex p-3 mb-3">
                            {{ ux_icon(project.icon, {style: 'width: 2rem; height: 2rem;'}) }}
                        </div>
                        <h3 class="h5 card-title fw-bold mb-3">{{ project.name }}</h3>
                        <p class="card-text text-muted mb-4 small">{{ project.description }}</p>
                    </div>
                    <div class="card-footer bg-transparent border-0 p-4 pt-0">
                        <div class="d-grid">
                            {% if project.route or project.url %}
                                <a href="{{ project.route ? path(project.route) : project.url }}" class="btn btn-outline-primary">Open Tool</a>
                            {% else %}
                                <button class="btn btn-outline-secondary disabled" title="Coming soon">Coming Soon</button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>

    <footer class="text-center text-muted py-5 border-top">
        <p>&copy; {{ "now"|date("Y") }} Hub. All rights reserved.</p>
    </footer>
</div>

<style>
    .hover-shadow:hover {
        transform: translateY(-5px);
        box-shadow: 0 .5rem 1rem rgba(0,0,0,.15)!important;
    }
    .transition {
        transition: all 0.3s ease;
    }
</style>
{% endblock %}
