{% extends 'base.html.twig' %}

{% block title %}Hub - Your Mini App Collection{% endblock %}

{% block body %}
<div class="hero-section text-center">
    <div class="container">
        <div class="row">
            <div class="col-lg-8 mx-auto">
        <span class="badge badge-custom px-3 py-2 mb-3">Zentralisierte Plattform</span>
        <h1 class="display-3 fw-extra-bold mb-4 tracking-tight">Deine praktischen Tools</h1>
        <p class="lead mb-0 opacity-75">Eine kuratierte Sammlung kleiner, nützlicher Werkzeuge für deinen Alltag. Alles, was du brauchst, an einem Ort.</p>
            </div>
        </div>
    </div>
</div>

<div class="container projects-container pb-5">
    <div class="row g-4">
        {% for project in projects %}
            <div class="col-12 col-lg-6 col-xl-4">
                <div class="project-card d-flex flex-column h-100 overflow-hidden">
                    {% if project.image %}
                        <div class="project-image-wrapper">
                            <img src="{{ project.image }}" class="img-fluid w-100" alt="{{ project.name }}">
                        </div>
                    {% endif %}
                    <div class="p-4 d-flex flex-column flex-grow-1">
                        <div class="icon-wrapper">
                            {{ ux_icon(project.icon) }}
                        </div>
                        <h3 class="h4 fw-bold mb-3">{{ project.name }}</h3>
                        <p class="text-muted mb-4 flex-grow-1">{{ project.description }}</p>

                        <div class="mt-auto">
                            {% if project.route or project.url %}
                                <a href="{{ project.route ? path(project.route) : project.url }}" class="btn btn-primary w-100 d-flex align-items-center justify-content-center">
                                    Tool öffnen {{ ux_icon('lucide:arrow-right', {class: 'ms-2', style: 'font-size: 0.8em;'}) }}
                                </a>
                            {% else %}
                                <button class="btn btn-light w-100 disabled" title="In Kürze verfügbar">
                                    In Kürze verfügbar
                                </button>
                            {% endif %}
                        </div>
                    </div>
                </div>
            </div>
        {% endfor %}
    </div>
</div>

<style>
    .fw-extra-bold { font-weight: 800; }
    .tracking-tight { letter-spacing: -0.025em; }
</style>
{% endblock %}
